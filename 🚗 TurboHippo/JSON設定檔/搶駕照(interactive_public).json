      "parameters": {
        "jsCode": "return $input.all().map(item => {\n    // 抓取這個人查詢到的網頁原始碼\n    const html = item.json.data || JSON.stringify(item.json);\n    const match = html.match(/preAdd\\(\\s*'([\\d-]+)'\\s*,\\s*'(\\d+)'\\s*,\\s*'(\\d+)'\\s*\\)/);\n\n    if (!match) {\n        // 找不到按鈕：給他一個 hasButton = false 的標籤\n        item.json.hasButton = false;\n    } else {\n        // 找到按鈕：給他 hasButton = true，並塞入專屬他的報名參數\n        item.json.hasButton = true;\n        item.json.secDate = match[1];\n        item.json.secId = match[2];\n        item.json.divId = match[3];\n    }\n    \n    // 把這筆資料完好無缺地傳給下一關\n    return item;\n});"
      },
