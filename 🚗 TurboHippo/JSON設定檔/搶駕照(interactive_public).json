    {
      "parameters": {
        "jsCode": "// 1. 取得原始資料\nconst html = $input.item.json.data || \"\"; \nconst predictDateStr = $('設定全域參數').item.json.expectExamDateStr.toString().trim(); \nconst typeCode = $('設定全域參數').item.json.licenseTypeCode;\nconst dmvNo = $('設定全域參數').item.json.dmvNo; \n\n// 2. 對照表：車種與監理站\nconst typeMap = {\n    '3': '普通重型機車', '5': '普通輕型機車 (50cc 以下)', 'A': '普通小型車',\n    'B': '職業小型車', 'C': '普通大貨車', 'D': '職業大貨車',\n    'E': '普通大客車', 'F': '職業大客車', 'G': '普通聯結車', 'H': '職業聯結車'\n};\nconst targetType = typeMap[typeCode] || '未知車種';\n\nconst dmvMap = {\n    '21': '士林', '25': '基隆', '26': '金門', '28': '連江',\n    '40': '臺北區', '41': '板橋', '43': '宜蘭', '44': '花蓮', '45': '玉里', '46': '蘆洲',\n    '50': '新竹區', '51': '新竹市', '52': '桃園', '53': '中壢', '54': '苗栗',\n    '60': '臺中區', '61': '臺中市', '62': '埔里', '63': '豐原', '64': '彰化', '65': '南投',\n    '70': '嘉義區', '71': '東勢', '72': '雲林', '73': '新營', '74': '臺南', '75': '麻豆', '76': '嘉義市',\n    '30': '高雄市區', '31': '苓雅', '33': '旗山',\n    '80': '高雄區', '81': '臺東', '82': '屏東', '83': '恆春', '84': '澎湖'\n};\nconst targetDmv = dmvMap[dmvNo] || \"\"; \n\n// 3. 核心日期處理函數：強制轉為 7 位數數字 (例如 1150416)\nfunction toDateNum(str) {\n    if (!str) return 0;\n    let year, month, day;\n    const s = str.toString().replace(/[^0-9]/g, '');\n\n    if (s.length === 7) { // 1150416\n        year = parseInt(s.substring(0, 3));\n        month = parseInt(s.substring(3, 5));\n        day = parseInt(s.substring(5, 7));\n    } else if (s.length === 8 && s.startsWith('20')) { // 20260416\n        year = parseInt(s.substring(0, 4)) - 1911;\n        month = parseInt(s.substring(4, 6));\n        day = parseInt(s.substring(6, 8));\n    } else {\n        const chineseMatch = str.toString().match(/(\\d{3})年(\\d{1,2})月(\\d{1,2})日/);\n        if (chineseMatch) {\n            year = parseInt(chineseMatch[1]);\n            month = parseInt(chineseMatch[2]);\n            day = parseInt(chineseMatch[3]);\n        }\n    }\n    // 確保回傳純數字：YYYMMDD\n    return (year && month && day) ? (year * 10000 + month * 100 + day) : 0;\n}\n\nconst predictDateNum = toDateNum(predictDateStr);\n\n// 4. 解析 HTML 表格\nconst records = html.split('</tr>'); \nlet isSuccess = false;\nlet finalDate = \"未知日期\";\nlet errorDetails = \"查無此人的報名紀錄（請確認是否報名成功）\";\n\nfor (let record of records) {\n    // 必須有「取消報名」按鈕才視為有效紀錄\n    if (record.includes(\"取消報名\")) {\n        const hasDmv = record.includes(targetDmv);\n        const hasType = record.includes(targetType);\n        const dateMatch = record.match(/(\\d{3})年(\\d{1,2})月(\\d{1,2})日/);\n\n        if (hasDmv && hasType) {\n            if (dateMatch) {\n                const foundDateNum = toDateNum(dateMatch[0]);\n                \n                // 【核心邏輯】找到日期 >= 預計日期 (含當天)\n                if (Number(foundDateNum) >= Number(predictDateNum) && predictDateNum !== 0) {\n                    isSuccess = true;\n                    finalDate = dateMatch[0];\n                    errorDetails = \"全部符合\";\n                    break;\n                } else {\n                    errorDetails = `日期不符：系統找到${dateMatch[0]}，但您要求 ${predictDateStr} (含)之後的場次。`;\n                }\n            }\n        } else if (hasDmv && !hasType) {\n            errorDetails = `在${targetDmv} 有紀錄，但車種不符 (需要：${targetType})`;\n        } else if (!hasDmv && hasType) {\n            errorDetails = `有報名${targetType}，但地點不符 (目標：${targetDmv}監理站)`;\n        }\n    }\n}\n\nreturn {\n    isSuccess,\n    finalDate,\n    errorDetails,\n    targetType,\n    targetDmv: targetDmv + \"監理站\",\n    userName: $('設定全域參數').item.json.name,\n    rowNumber: $('引入參數').item.json.row_number \n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1984,
        -224
      ],
      "id": "b17a4d62-48e2-4f54-92ec-c4fd9e15a470",
      "name": "判斷報名結果"
    },
    {
      "parameters": {
        "authentication": "serviceAccount",
        "operation": "delete",
